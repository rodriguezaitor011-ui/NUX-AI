# NUX IA - Environment Variables Example
# Copy this file to .env and fill in your values

# ============================================
# API KEYS (REQUIRED)
# ============================================

# Groq API Key (https://console.groq.com/keys)
GROQ_API_KEY=your_groq_api_key_here

# DeepSeek API Key (https://platform.deepseek.com/api_keys)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# OpenAI API Key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=your_openai_api_key_here

# ============================================
# SECURITY (REQUIRED)
# ============================================

# Secret key for JWT tokens (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=your_secret_key_here_minimum_32_characters

# Admin emails (comma-separated)
ADMIN_EMAILS=admin@example.com,another_admin@example.com

# CORS origins (comma-separated, use * for development only)
CORS_ORIGINS=*

# ============================================
# DATABASE
# ============================================

# PostgreSQL URL (Render provides this automatically)
# For local development with SQLite: sqlite:///./database/nux_local.db
DATABASE_URL=sqlite:///./database/nux_local.db

# ============================================
# APPLICATION SETTINGS
# ============================================

# Environment: development or production
ENVIRONMENT=development

# Debug mode (True/False)
DEBUG=True

# ============================================
# LIMITS AND CONFIGURATION
# ============================================

# Maximum text length for processing (characters)
MAX_TEXT_LENGTH=500000

# Maximum instructions length (characters)
MAX_INSTRUCTIONS_LENGTH=200

# Rate limit per minute per IP
RATE_LIMIT_PER_MINUTE=10

# ============================================
# OCR CONFIGURATION
# ============================================

# OpenAI model for OCR (gpt-4o recommended)
OPENAI_OCR_MODEL=gpt-4o

# Maximum image size for OCR (bytes)
OCR_MAX_IMAGE_SIZE=10485760  # 10 MB

# ============================================
# AI MODEL CONFIGURATION
# ============================================

# Groq model for summarization
GROQ_MODEL=llama-3.3-70b-versatile

# Maximum tokens for AI responses
MAX_TOKENS=2048

# Temperature for AI responses (0.0 to 1.0)
TEMPERATURE=0.7