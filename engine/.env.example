# NUX IA - Environment Configuration Example
# Copia este archivo a .env y personaliza con tus valores

# ===========================
# OpenAI Configuration (REQUIRED)
# ===========================
# Obtén tu API key en: https://platform.openai.com/api/keys
OPENAI_API_KEY=sk-your-api-key-here

# Modelos disponibles:
# - gpt-4o (recomendado, más potente y más caro)
# - gpt-4-turbo (balance costo/calidad)
# - gpt-3.5-turbo (más económico)
OPENAI_MODEL=gpt-4o
OPENAI_OCR_MODEL=gpt-4o

# ===========================
# Security (REQUIRED)
# ===========================
# Genera una clave segura con: python -c 'import secrets; print(secrets.token_urlsafe(32))'
SECRET_KEY=your-super-secret-key-change-me

# ===========================
# Application Settings
# ===========================
ENVIRONMENT=development
DEBUG=False
APP_NAME=NUX IA

# ===========================
# Text Processing
# ===========================
MAX_TOKENS=2048
TEMPERATURE=0.7
MAX_TEXT_LENGTH=500000
MAX_INSTRUCTIONS_LENGTH=200

# ===========================
# Image/OCR Settings
# ===========================
# Tamaño máximo de imagen en bytes (10 MB por defecto)
OCR_MAX_IMAGE_SIZE=10485760

# ===========================
# Rate Limiting
# ===========================
# Máximo de requests por minuto
RATE_LIMIT_PER_MINUTE=10

# ===========================
# Database
# ===========================
# SQLite por defecto (development)
DATABASE_URL=sqlite:///database/studia.db

# Para producción, usa PostgreSQL o similar:
# DATABASE_URL=postgresql://user:password@localhost/dbname

# ===========================
# CORS Configuration
# ===========================
# Para desarrollo: "*" (permite todos los orígenes)
# Para producción: especifica dominios separados por comas
# Ejemplo: "https://tudominio.com,https://www.tudominio.com"
CORS_ORIGINS=*

# ===========================
# Admin Configuration
# ===========================
# Emails de administradores (separados por comas)
# ADMIN_EMAILS=admin@example.com,manager@example.com
ADMIN_EMAILS=

# ===========================
# Logging
# ===========================
LOG_LEVEL=INFO

# ===========================
# Notas Importantes
# ===========================
# 1. OPENAI_API_KEY es OBLIGATORIO para que funcione la app
# 2. Mantén SECRET_KEY seguro y diferente en producción
# 3. En producción, NO uses DEBUG=True
# 4. En producción, NO uses CORS_ORIGINS=*
# 5. Revisa los precios de OpenAI: https://openai.com/pricing
# 6. Activa límites de costos en tu cuenta de OpenAI
